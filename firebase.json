{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git",
      ".git/**",
      ".github",
      ".github/**",
      ".gitignore",
      ".nojekyll",
      "README.md",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.log",
      "y/**",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
